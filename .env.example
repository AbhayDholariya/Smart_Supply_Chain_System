# ─── Django ───────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────
# For Docker (PostgreSQL)
POSTGRES_DB=smart_supply_chain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# For Local Dev (SQLite is used automatically in config/settings/development.py)

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── External APIs (for Live Map & Weather) ───────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
WEATHER_API_KEY=your-weather-api-key

# ─── Celery (for async tasks - optional for local dev) ────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Frontend ─────────────────────────────────────────────
# For Docker deployment, set to your backend URL (e.g., http://localhost/api/v1)
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
